from abc import ABC, abstractmethod

class Notifier(ABC):
    @abstractmethod
    def send(self, message: str, recipient: str):
        pass


from notifier_base import Notifier

class EmailNotifier(Notifier):
    def __init__(self):
        self.smtp_server = "smtp.proje-team.local"

    def send(self, message: str, recipient: str):
        print(f"[BAĞLANTI] {self.smtp_server} sunucusuna bağlanılıyor...")
        print("[FORMAT] Mesaj HTML formatına çevriliyor...")
        print(f"[GÖNDERİM] Email başarıyla gönderildi -> Alıcı: {recipient}")
        print(f"[İÇERİK] <h1>{message}</h1>\n")

