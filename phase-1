class SMSNotifier(Notifier):
    def __init__(self):
        self.api_key = "PROJE-SMS-KEY-9988"

    def send(self, message: str, recipient: str):
        print(f"[KİMLİK DOĞRULAMA] SMS API Anahtarı doğrulanıyor: {self.api_key}")
        if len(message) > 160:
            print("[UYARI] Mesaj 160 karakterden uzun, bölünüyor...")
            message = message[:157] + "..."
        print(f"[GÖNDERİM] SMS başarıyla gönderildi -> Tel: {recipient}")
        print(f"[İÇERİK] {message}\n")

